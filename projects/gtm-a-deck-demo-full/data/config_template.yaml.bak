# GTM A-Deck 演示PPT 数据配置模板
# 所有业务数据应该在这里定义，不应该硬编码在装载器中
# 每个装载器通过 data[""] 获取所需数据

# ============================================================================
# G1: 市场定位 (GM-01 ~ GM-04)
# ============================================================================
g1_positioning:
  gm_01_positioning_statement:
    title: "GM-01 Positioning Statement | A-Deck 市场定位"
    subtitle: "For 产品/营销团队 | 结构化定位链路"
    content:
      target: "产品团队与营销团队\n(200-10K人规模企业)"
      problem: "PPT制作慢且风格不一致\n手工协作成本高"
      product: "A-Deck\n企业级PPT生成平台"
      differentiator: "模板智能 + AI生成\n品牌规范自动约束"
      category: "Enterprise PPT Automation"

  gm_02_buyer_journey:
    title: "GM-02 Buyer Journey | 采购方决策路径"
    subtitle: "For 销售团队 | 5个关键决策阶段"
    content:
      stages:
        - label: "Problem\nAwareness"
          desc: "认知问题"
          triggers:
            - "PPT制作效率低下"
            - "风格不一致"
        - label: "Explore"
          desc: "评估方案"
          triggers:
            - "对标竞品"
            - "试用体验"
        - label: "Consideration"
          desc: "方案选择"
          triggers:
            - "成本效益分析"
            - "团队反馈"
        - label: "Decision"
          desc: "最终采购"
          triggers:
            - "合同签署"
            - "实施规划"
        - label: "Advocacy"
          desc: "持续推广"
          triggers:
            - "成功案例"
            - "口碑传播"

  gm_03_competitor_matrix:
    title: "GM-03 Competitor Positioning Matrix | 竞争格局"
    subtitle: "For 产品/市场 | 根据模板智能度 vs. AI生成能力定位"
    content:
      x_label: "模板智能度"
      y_label: "AI生成能力"
      competitors:
        - name: "A-Deck"
          x: 8.5
          y: 8.0
          color: [0, 204, 215]  # 品牌青色
          size: 300
          label: "Leader"
        - name: "Canva"
          x: 7.0
          y: 6.5
          color: [100, 150, 200]
          size: 200
        - name: "Microsoft Designer"
          x: 6.5
          y: 7.0
          color: [100, 150, 200]
          size: 200
        - name: "Adobe Express"
          x: 7.5
          y: 6.0
          color: [100, 150, 200]
          size: 200
        - name: "传统PowerPoint"
          x: 4.0
          y: 2.0
          color: [150, 150, 150]
          size: 150

  gm_04_market_sizing:
    title: "GM-04 Market Sizing | 市场规模评估"
    subtitle: "For 投资者/高管 | TAM/SAM/SOM分析"
    content:
      tam:
        value: "$48.2B"
        description: "全球企业PPT制作市场（总可寻址市场）"
      sam:
        value: "$8.5B"
        description: "中国+东南亚中型企业PPT自动化市场"
      som:
        value: "$320M"
        description: "A-Deck 第5年目标可获市场份额（3.8%）"
      assumptions:
        - "全球400M知识工作者，40%需要PPT"
        - "平均PPT年制作成本 $12K/人（时间成本）"
        - "亚太区占全球市场28%"

# ============================================================================
# G2: 买方价值 (GM-05 ~ GM-08)
# ============================================================================
g2_buyer_value:
  gm_05_value_driver_tree:
    title: "GM-05 Value Driver Tree | 价值驱动树"
    subtitle: "For 高管/CFO | 从收入、成本、风险角度的价值分解"
    content:
      total_value: "总价值：每年节省成本 $8.6K/用户"
      drivers:
        revenue_growth:
          title: "收入增长"
          impact: "$2.4K"
          levers:
            - "参提案周期缩短40%，赢率提升15%"
            - "客户呈现专业度提高，续费率+8%"
        cost_reduction:
          title: "成本降低"
          impact: "$4.2K"
          levers:
            - "PPT制作时间从15h降至3h"
            - "设计人员成本节省40%"
        risk_reduction:
          title: "风险降低"
          impact: "$2.0K"
          levers:
            - "品牌规范合规性100%"
            - "法务/审批流程自动化，风险漏洞减少"

  gm_06_capability_outcome_trace:
    title: "GM-06 Capability-Outcome Trace Matrix | 能力-结果映射"
    subtitle: "For 产品/销售 | 从A-Deck功能到业务成果的关联"
    content:
      mappings:
        - capability: "AI生成PPT内容"
          users: "所有角色"
          outcome: "制作时间↓60%"
          business_result: "成本节省 $4.2K/年"
        - capability: "企业模板库"
          users: "市场/销售"
          outcome: "风格一致性↑95%"
          business_result: "品牌价值提升"
        - capability: "权限/审批流"
          users: "管理员"
          outcome: "规范合规性100%"
          business_result: "风险规避 $2.0K/年"
        - capability: "多人协作"
          users: "项目组"
          outcome: "协作效率↑80%"
          business_result: "团队满意度↑25%"

  gm_07_time_to_value:
    title: "GM-07 Time-To-Value Curve | 价值实现时间曲线"
    subtitle: "For 采购/CTO | 投资回报周期"
    content:
      stages:
        - week: 1
          cumulative_value: "$200"
          phase: "部署完成"
        - week: 2
          cumulative_value: "$800"
          phase: "模板适配"
        - week: 4
          cumulative_value: "$3,400"
          phase: "团队培训"
        - week: 8
          cumulative_value: "$6,800"
          phase: "生产应用"
        - week: 12
          cumulative_value: "$8,600"
          phase: "完全收益"
      roi_breakeven: "第4周"

  gm_08_baseline_target_kpi:
    title: "GM-08 Baseline → Target KPI | 基线与目标"
    subtitle: "For CFO/PMO | 关键指标改进"
    content:
      kpis:
        - metric: "PPT制作时间/份"
          baseline: "15小时"
          target: "3小时"
          improvement: "↓80%"
        - metric: "年度人均PPT制作成本"
          baseline: "$12,000"
          target: "$2,400"
          improvement: "↓80%"
        - metric: "设计团队产出倍数"
          baseline: "1x"
          target: "6x"
          improvement: "↑600%"
        - metric: "客户提案成功率"
          baseline: "22%"
          target: "32%"
          improvement: "↑45%"

# ============================================================================
# G3: 解决方案 (GM-09 ~ GM-12)
# ============================================================================
g3_solution:
  gm_09_solution_architecture:
    title: "GM-09 Solution Architecture | 方案架构"
    subtitle: "For CTO/技术团队 | 系统全景"
    content:
      layers:
        - name: "呈现层"
          components:
            - "PPT编辑器 (Web/Desktop)"
            - "浏览器集成"
        - name: "应用层"
          components:
            - "模板引擎"
            - "AI内容生成"
            - "协作管理"
        - name: "业务层"
          components:
            - "权限/审批"
            - "品牌规范"
            - "版本管理"
        - name: "数据/基础设施"
          components:
            - "模板库 DB"
            - "用户内容存储"
            - "LLM集成"

  gm_10_deployment_model:
    title: "GM-10 Deployment Model | 部署模式"
    subtitle: "For IT/架构 | 支持SaaS/私有部署"
    content:
      deployment_options:
        - type: "Cloud SaaS"
          features: ["弹性扩展", "自动更新", "全球CDN"]
          timeline: "立即上线"
        - type: "VPC/私有云"
          features: ["数据隔离", "定制集成", "审计完整"]
          timeline: "4周部署"
        - type: "本地部署"
          features: ["完全隔离", "极速响应", "离线运行"]
          timeline: "8周部署"

  gm_11_ai_model_integration:
    title: "GM-11 AI Model Integration | AI模型集成"
    subtitle: "For 产品/技术 | 内容生成能力"
    content:
      models:
        - name: "内容大纲生成"
          provider: "ChatGPT 4"
          latency: "<5s"
        - name: "文案撰写"
          provider: "Claude 3.5"
          latency: "<8s"
        - name: "视觉设计"
          provider: "Vision + Stable Diffusion"
          latency: "<30s"
        - name: "多语言翻译"
          provider: "DeepL/本地模型"
          latency: "<3s"

  gm_12_integration_ecosystem:
    title: "GM-12 Integration Ecosystem | 集成生态"
    subtitle: "For 技术/产品 | 与企业系统协作"
    content:
      integrations:
        - category: "数据源"
          items:
            - "Salesforce (销售数据)"
            - "Tableau (分析数据)"
            - "Google Drive / OneDrive"
        - category: "工作流"
          items:
            - "Slack通知"
            - "Outlook日历同步"
            - "JIRA任务关联"
        - category: "内容分发"
          items:
            - "SharePoint"
            - "Teams集成"
            - "企业知识库"

# ============================================================================
# G4: 实施 (GM-13 ~ GM-17)
# ============================================================================
g4_implementation:
  gm_13_rollout_plan:
    title: "GM-13 Rollout Plan | 推出计划"
    subtitle: "For 项目经理/采购 | 12周实施路线"
    content:
      phases:
        - phase: 1
          weeks: "1-2"
          name: "需求梳理"
          deliverables:
            - "企业架构评估"
            - "权限体系设计"
            - "模板定制需求"
        - phase: 2
          weeks: "3-4"
          name: "系统部署"
          deliverables:
            - "环境搭建"
            - "数据迁移"
            - "集成测试"
        - phase: 3
          weeks: "5-8"
          name: "试点运营"
          deliverables:
            - "200人试点"
            - "反馈迭代"
            - "文档完善"
        - phase: 4
          weeks: "9-12"
          name: "全量推出"
          deliverables:
            - "全员培训"
            - "生产切换"
            - "后期支持"

  gm_14_training_program:
    title: "GM-14 Training Program | 培训计划"
    subtitle: "For 持续运营 | 3层次、多模式"
    content:
      training_tracks:
        - role: "管理员"
          duration: "2天"
          topics:
            - "系统部署和配置"
            - "用户权限管理"
            - "审批流程设置"
        - role: "超级用户"
          duration: "1天"
          topics:
            - "高级功能应用"
            - "AI功能掌握"
            - "团队支持方法"
        - role: "普通用户"
          duration: "2小时"
          topics:
            - "基础操作"
            - "常用模板"
            - "快速生成方法"

  gm_15_adoption_metrics:
    title: "GM-15 Adoption Metrics | 采用率指标"
    subtitle: "For 运营/高管 | 成功衡量"
    content:
      metrics:
        - metric: "活跃用户率"
          target: "70%"
          month: "第3个月"
        - metric: "每用户月均生成PPT"
          target: "8个"
          month: "第4个月"
        - metric: "平均制作时间"
          target: "<3小时"
          month: "第5个月"
        - metric: "用户满意度"
          target: ">4.0/5.0"
          month: "第6个月"
      tracking:
        - "周度使用报表"
        - "月度对标review"
        - "季度采用分析"

  gm_16_support_model:
    title: "GM-16 Support Model | 支持模式"
    subtitle: "For 运营/客成 | 多层级支持体系"
    content:
      support_tiers:
        - tier: 1
          name: "自助支持"
          channels:
            - "FAQ文档库"
            - "视频教程"
            - "社区论坛"
          response: "实时"
        - tier: 2
          name: "L1技术支持"
          channels:
            - "Email工单"
            - "在线客服"
          response: "<4小时"
        - tier: 3
          name: "顾问级支持"
          channels:
            - "专属客成经理"
            - "定期运营review"
          response: "<24小时"

  gm_17_success_criteria:
    title: "GM-17 Success Criteria | 成功标准"
    subtitle: "For 客户/CSM | 清晰的成功定义"
    content:
      success_gates:
        - gate: "30天"
          criteria:
            - "系统部署完成"
            - "100%用户账户激活"
            - "3+模板适配完成"
        - gate: "90天"
          criteria:
            - "50%活跃用户率"
            - "平均PPT制作时间 <5小时"
            - "0个严重缺陷"
        - gate: "180天"
          criteria:
            - "70%活跃用户率"
            - "平均PPT制作时间 <3小时"
            - "用户满意度 4.0+ / 5.0"
            - "ROI > 150%"

# ============================================================================
# G5: GTM策略 (GM-18 ~ GM-22)
# ============================================================================
g5_gtm_strategy:
  gm_18_go_to_market_motion:
    title: "GM-18 Go-To-Market Motion | GTM运动"
    subtitle: "For 市场/销售 | 3维度GTM组合"
    content:
      motions:
        - motion: "Account-Based Marketing"
          description: "针对头部企业的定制化营销"
          target_segments: "Fortune 500"
          channels: ["直销", "战略合作", "高管邀请"]
        - motion: "Product-Led Growth"
          description: "免费试用驱动采用"
          target_segments: "创新型企业"
          channels: ["产品体验", "内容营销", "社区"]
        - motion: "Sales-Enabled Conversion"
          description: "通过销售加速B2B转化"
          target_segments: "中大型企业"
          channels: ["销售团队", "渠道伙伴", "集成商"]

  gm_19_market_segmentation:
    title: "GM-19 Market Segmentation | 市场分段"
    subtitle: "For 产品/市场 | 优先级分段"
    content:
      segments:
        - segment: "高优先级（1-2年内）"
          tam: "$2.1B"
          characteristics: "500+人、快速成长、数字化领先"
          personas: ["CMO", "产品负责人", "市场经理"]
        - segment: "中等优先级（2-3年）"
          tam: "$3.2B"
          characteristics: "200-500人、传统行业数字化"
          personas: ["销售VP", "运营总监"]
        - segment: "长尾市场（3+年）"
          tam: "$3.2B"
          characteristics: "<200人、中小型组织"
          personas: ["创业公司", "组织团队"]

  gm_20_channel_strategy:
    title: "GM-20 Channel Strategy | 渠道策略"
    subtitle: "For 渠道/合作 | 多渠道组合"
    content:
      channels:
        - channel: "直销团队"
          target_contracts: "$500K+"
          coverage: "50份客户"
          model: "组织内销售"
        - channel: "渠道伙伴"
          target_contracts: "$100K-500K"
          coverage: "200份客户"
          model: "生态集成商"
        - channel: "SaaS平台"
          target_contracts: "$1K-50K"
          coverage: "5000+用户"
          model: "自助购买"

  gm_21_pricing_model:
    title: "GM-21 Pricing Model | 价格模式"
    subtitle: "For 产品/财务 | 基于价值的定价"
    content:
      pricing_tiers:
        - tier: "Starter"
          price: "$49/月"
          users: "1-5"
          features:
            - "基础模板库"
            - "3个品牌规范"
            - "社区支持"
        - tier: "Professional"
          price: "$299/月"
          users: "6-50"
          features:
            - "完整模板库"
            - "企业定制"
            - "优先支持"
        - tier: "Enterprise"
          price: "按需定价"
          users: "50+"
          features:
            - "专属API"
            - "24/7支持"
            - "定制开发"

  gm_22_engagement_model:
    title: "GM-22 Engagement Model | 互动模式"
    subtitle: "For 销售/客成 | 客户旅程互动"
    content:
      lifecycle_phases:
        - phase: "Awareness"
          duration: "1-2周"
          tactics:
            - "行业报告"
            - "网络研讨会"
            - "案例分享"
        - phase: "Consideration"
          duration: "2-4周"
          tactics:
            - "产品demo"
            - "竞对对比"
            - "ROI计算"
        - phase: "Purchase"
          duration: "1-2周"
          tactics:
            - "合同谈判"
            - "实施规划"
        - phase: "Success"
          duration: "持续"
          tactics:
            - "定期review"
            - "扩展销售"
            - "用户社区"

# ============================================================================
# G6: 产品特性 (GM-23 ~ GM-25)
# ============================================================================
g6_product_feature:
  gm_23_feature_capability_matrix:
    title: "GM-23 Feature-Capability Matrix | 能力全景"
    subtitle: "For 产品团队 | 核心功能与企业能力对应"
    content:
      sections:
        - title: "智能能力"
          items:
            - "自动大纲生成：AI理解内容→智能组织层级"
            - "智能配图：扫描内容→推荐相关图表/图片"
            - "专业排版：尊重品牌规范→自动对齐/配色"

        - title: "协作能力"
          items:
            - "团队编辑：实时多人协作→版本管理"
            - "权限管理：细粒度角色→品牌一致性保证"
            - "审批流程：内容审值→自动合规检查"

        - title: "集成能力"
          items:
            - "模板库API：连接企业内容源→自动同步数据"
            - "Single Sign-On：与企业目录对接→降低部署成本"
            - "导出格式：支持PPTX/PDF/视频→灵活发布"

  gm_24_feature_differentiation_radar:
    title: "GM-24 Feature Differentiation | 竞争差异化"
    subtitle: "For 营销团队 | vs竞品的核心优势"
    content:
      sections:
        - title: "AI智能度"
          items:
            - "✓ 内容生成支持中文行业术语"
            - "✓ 设计规范AI强化（vs Canva通用模型）"
            - "✓ 企业数据智能融合（vs开源工具无能力）"

        - title: "企业级功能"
          items:
            - "✓ 细粒度权限与合规（vs消费级无此功能）"
            - "✓ 品牌模板锁定（vs Designer需手工维护）"
            - "✓ 审批流程与版本管理（vs传统PPT靠人工）"

        - title: "集成生态"
          items:
            - "✓ 支持企业SSO与数据源（vs竞品API受限）"
            - "✓ 国产化适配与合规（vs国外工具本地化弱）"
            - "✓ 定制开发与灵活扩展（vs标准SaaS无法定制）"

  gm_25_feature_usecase_mapping:
    title: "GM-25 Usecase Mapping | 典型场景"
    subtitle: "For 销售/成功 | 客户实际应用场景"
    content:
      sections:
        - title: "销售场景"
          items:
            - "客户提案加速：1天出稿vs周级手工→赢单竞速优势"
            - "竞对分析展示：快速数据可视化→决策支持"
            - "行业对标报告：批量生成图表→销售工具库"

        - title: "营销场景"
          items:
            - "活动物料制作：品牌规范自动约束→降低重做率"
            - "内容日历管理：社媒/官网/通讯稿→统一品牌形象"
            - "市场宣传资料库：模板复用→大幅降低改稿周期"

        - title: "企业内部"
          items:
            - "财务汇报：自动图表生成→老板演讲用稿快速成型"
            - "项目总结：标准化模板→知识沉淀与传承"
            - "员工培训教材：批量生成→培训内容统一管理"

# ============================================================================
# G7: 价值实现 (GM-26 ~ GM-30)
# ============================================================================
g7_value_realization:
  gm_26_value_realization_roadmap:
    title: "GM-26 Value Realization Roadmap | 价值阶梯"
    subtitle: "For 客成/市场 | 客户从试用到习惯转变"
    content:
      sections:
        - title: "第1个月：快速体验期"
          items:
            - "价值：快速制作第一份PPT (2h vs 2天)"
            - "指标：3-5个用户激活，首份文件生成"
            - "推动：产品演练+快速模板入库"

        - title: "第2-3个月：部门应用期"
          items:
            - "价值：团队协作降低30%沟通成本"
            - "指标：覆盖5+部门，月均20+文件生成"
            - "推动：权限/审批流程上线，团队培训"

        - title: "第4-6个月：规模化期"
          items:
            - "价值：企业品牌规范自动执行，降低风险"
            - "指标：公司级模板库建成，合规率100%"
            - "推动：API/SSO集成，与业务系统打通"

        - title: "第7-12个月：习惯化期"
          items:
            - "价值：成为企业日常PPT工具，成本永久降低"
            - "指标：DAU/MAU健康增长，自然推荐率高"
            - "推动：高级功能开放，定制营销物料"

  gm_27_benefit_realization_timeline:
    title: "GM-27 Benefit Realization Timeline | 收益时间表"
    subtitle: "For CFO/CEO | 投资回报周期"
    content:
      sections:
        - title: "投资周期（第1-2个月）"
          items:
            - "实施成本：部署+培训约50-100K RMB"
            - "预期活跃率：30-50%（持续教育中）"
            - "KPI：系统稳定性>99.5%，用户反馈NPS>50"

        - title: "收益初期（第3-4个月）"
          items:
            - "人力成本降低：3-5人团队可省1-2人/月工作量"
            - "机会成本降低：提案周期从7天缩短到1-2天"
            - "预期ROI：~30-40% (quarterly)"

        - title: "规模收益（第5-12个月）"
          items:
            - "团队效率：营销/销售团队月效率提升50-70%"
            - "品牌风险降低：合规审批自动化，差错率降95%"
            - "预期ROI：~100-150% (annual)"

  gm_28_persona_value_mapping:
    title: "GM-28 Persona Value Mapping | 角色价值链"
    subtitle: "For 产品/营销 | 各角色感知价值"
    content:
      sections:
        - title: "CEO/CMO的价值"
          items:
            - "品牌保护：规范一致性自动约束→降低失控风险"
            - "成本控制：人力成本年省200K+→提高利润率"
            - "决策支持：可视化BI仪表板→信息决策快速化"

        - title: "营销经理的价值"
          items:
            - "工作效率：制作时间减少80%→可做更多创意工作"
            - "协作顺畅：审批流程自动化→从周级改为日级"
            - "库存管理：资产库版本管理→不用拷贝粘贴"

        - title: "设计师的价值"
          items:
            - "专业度：AI基础排版→节省40%基础工作时间"
            - "创意释放：多余精力→专注高价值design创新"
            - "复用资产：组件库沉淀→设计体系化"

        - title: "销售经理的价值"
          items:
            - "竞速能力：快速定制提案→提升赢单概率"
            - "信心加磅：专业视觉→客户信任度提升"
            - "规模化：模板应用→新销售快速上手"

  gm_29_proof_evidence_ladder:
    title: "GM-29 Proof & Evidence Ladder | 证据阶梯"
    subtitle: "For 销售/市场 | 信任递进式证据"
    content:
      sections:
        - title: "第1级：产品证据（现场体验）"
          items:
            - "Live Demo：10分钟现场制作PPT与手工对比"
            - "免费试用：7天企业版完整功能体验"

        - title: "第2级：数据证据（量化指标）"
          items:
            - "效率数据：平均PPT制作时间从180min→20min"
            - "用户数据：50+企业1000+用户，月活跃度70%"
            - "成本数据：年均人力成本降低30-50%"

        - title: "第3级：案例证据（同行参考）"
          items:
            - "行业案例：TOP 5互联网公司已应用（可见公式客户）"
            - "规模案例：500-5000人企业，全公司推广"
            - "垂直案例：金融/电信/制造行业适配方案"

        - title: "第4级：第三方认证"
          items:
            - "媒体报道：国内AI领先产品50强入选"
            - "奖项认证：企业软件创新大赛金奖"
            - "分析师报告：Gartner魔力象限候选"

  gm_30_assumption_validation_table:
    title: "GM-30 Assumption Validation | 假设验证"
    subtitle: "For 产品/战略 | 销售路径关键假设"
    content:
      sections:
        - title: "假设1：市场需求深度 (风险-低)"
          items:
            - "假设：PPT制作是企业日常高频痛点"
            - "验证方式：500+企业问卷，82%确认这是痛点"
            - "结论：✓ 验证通过，市场需求确实"

        - title: "假设2：付费意愿度 (风险-中)"
          items:
            - "假设：企业愿为提效工具年付5-20K"
            - "验证方式：客户试用后续约、购买周期"
            - "结论：✓ 70%试用客户3个月内续约"

        - title: "假设3：集成可行性 (风险-中)"
          items:
            - "假设：能与企业SSO/数据源平顺集成"
            - "验证方式：与TOP 3客户的集成实施周期"
            - "结论：✓ 均在3周内完成，满足预期"

        - title: "假设4：竞品替代风险 (风险-高)"
          items:
            - "假设：通用设计工具短期难以追赶企业差异化"
            - "验证方式：竞品路线图分析、客户留存率"
            - "结论：⚠ 需持续监测，投资防守型创新"

# ============================================================================
# G8: 风险管理 (GM-31 ~ GM-35)
# ============================================================================
g8_risk_management:
  gm_31_risk_reduction_heatmap:
    title: "GM-31 Risk Reduction Heatmap | 风险热力图"
    subtitle: "For CEO/COO | 从上市到规模化核心风险"
    content:
      sections:
        - title: "产品风险 (年初:高 → 年末:中)"
          items:
            - "卡顿与稳定性：UX不流畅损伤留存 [HIGH→MEDIUM]"
            - "AI准确度：错误内容削弱信任 [MEDIUM→LOW]"
            - "功能完整性：缺核心能力被竞品侵蚀 [HIGH→MEDIUM]"

        - title: "市场风险 (年初:中 → 年末:中)"
          items:
            - "公司对标进入：大厂（如字节）推出竞品 [MEDIUM→HIGH]"
            - "价格战加剧：通用工具降价冲击中小客户 [LOW→MEDIUM]"
            - "需求不确定：宏观经济衰退减少企业投资 [MEDIUM→MEDIUM]"

        - title: "商业风险 (年初:中 → 年末:低-中)"
          items:
            - "销售扰动：渠道铺设不畅延后收入 [MEDIUM→MEDIUM]"
            - "客户集中度：TOP 5客户贡献>40%收入 [HIGH→MEDIUM]"
            - "留存下滑：首年付费客户续约不足预期 [MEDIUM→LOW]"

        - title: "战略风险 (年初:中 → 年末:中)"
          items:
            - "融资困难：融资周期拉长或估值压力 [MEDIUM→MEDIUM]"
            - "人才流失：核心AI团队被挖角 [LOW→MEDIUM]"
            - "政策监管：AI合规要求提升成本 [LOW→MEDIUM]"

  gm_32_competitive_threat_analysis:
    title: "GM-32 Competitive Threat Analysis | 竞争威胁"
    subtitle: "For 产品/市场 | 竞品分析与应对"
    content:
      sections:
        - title: "近期威胁 (半年内)"
          items:
            - "威胁1：Microsoft Designer 功能升级+Office集成天然优势"
            - "对策：强化行业差异化（金融/制造定制）、API集成覆盖优势"
            - "威胁2：开源竞品 + 初创融资活跃"
            - "对策：巩固商业客户，建立品牌/渠道护城河"

        - title: "中期威胁 (1年内)"
          items:
            - "威胁1：字节/腾讯等大厂进入，利用流量做免费版"
            - "对策：企业级深化、API生态、垂直行业领先"
            - "威胁2：Adobe 连接生态，打AI+设计+营销套件"
            - "对策：强调快速+中文适配+本地合规优势"

        - title: "长期威胃 (3年+)"
          items:
            - "威胁1：AI技术commoditize，差异化被抹平"
            - "对策：投资行业知识沉淀、企业数据智能集成"
            - "威胁2：市场从ToB转向ToC，走向下沉"
            - "对策：为时尚早，持续ToB领先优势沉淀"

  gm_33_mitigation_strategy_plan:
    title: "GM-33 Mitigation Strategy | 风险应对"
    subtitle: "For 执行团队 | 具体缓解措施"
    content:
      sections:
        - title: "产品稳定性与迭代"
          items:
            - "目标：保证UX流畅、功能完整、AI准确>95%"
            - "执行：周迭代+每日性能监控，建立AI模型验证流程"
            - "投入：40% 研发资源投向稳定性增强"

        - title: "客户粘性与超期价值"
          items:
            - "目标：新客首年留存率>80%，客单价年增20%"
            - "执行：NPS管理流程，定期customer success review，扩展销售推进"
            - "投入：客成团队规模翻倍，专属account manager"

        - title: "渠道与品牌建设"
          items:
            - "目标：进入主流媒体视野，渠道铺设10+合作伙伴"
            - "执行：坚持PR/市场活动，建立GSI/ISV合作生态"
            - "投入：市场预算年增50%，专项公关/品牌"

        - title: "融资与人才储备"
          items:
            - "目标：确保12+月现金储备，核心团队稳定"
            - "执行：提前融资规划(A轮→B轮规划)，股权激励加码"
            - "投入：融资团队优化，HR端人才竞争力提升"

  gm_34_adoption_barrier_analysis:
    title: "GM-34 Adoption Barrier Analysis | 采纳障碍"
    subtitle: "For 销售/客成 | 客户采纳关键卡点"
    content:
      sections:
        - title: "认知障碍 (30%客户)"
          items:
            - "存在问题：不知道AI PPT能做什么、ROI不清楚"
            - "客成策略：10分钟ROI计算工具、行业对标案例"
            - "销售策略：免费试用周+客户成功经理驱动"

        - title: "集成障碍 (20%客户)"
          items:
            - "存在问题：与现有IT系统（SSO/CRM/DMS）集成复杂"
            - "产品策略：预构建常见集成、低代码集成平台"
            - "实施策略：加快交付周期、提供技术支持"

        - title: "变革障碍 (25%客户)"
          items:
            - "存在问题：设计/营销团队习惯原流程，抵触新工具"
            - "客成策略：现场培训、超级用户认证计划"
            - "销售策略：从小部门/pilot开始、建立内部倡导者"

        - title: "成本障碍 (15%客户)"
          items:
            - "存在问题：定价超预算、ROI周期>1年难接受"
            - "产品策略：灵活计费模型、按需购买组件化"
            - "销售策略：分期付费、首年特殊折扣、成功才付款模式"

  gm_35_success_stories_roadmap:
    title: "GM-35 Success Stories Roadmap | 成功案例规划"
    subtitle: "For 市场/销售 | 客户见证与案例库"
    content:
      sections:
        - title: "Q1目标：3个深度案例 (已达成)"
          items:
            - "互联网头部：日均生成100+PPT，年省200K人力"
            - "金融客户：提案制作效率↑200%，签单率↑15%"
            - "制造企业：汇报标准化，审批流程缩短70%"

        - title: "Q2目标：8个行业案例库"
          items:
            - "新增目标：地产/教育/医疗/电商/汽车/快消产业链"
            - "执行策略：Deep dive audit + 视频见证 + ROI计算"
            - "形式输出：case study + webinar重播 + 客户推荐"

        - title: "Q3目标：行业标杆+第三方认证"
          items:
            - "战略案例：与行业头部1-2家打造联合方案"
            - "第三方认可：获得Gartner/Forrester适配推荐"
            - "媒体曝光：行业媒体访谈>10篇、知乎回答>50"

        - title: "Q4目标：品牌代言+规模化推广"
          items:
            - "品牌升级：与行业KOL建立言论，出版联合文章"
            - "客户见证：'A-Deck is our must-have' → 产品宣传"
            - "销售资产库：40+sales deck，覆盖各行业/部门"

